{
  "name": "docker-staticmaps",
  "description": "API for generating static map images",
  "author": "Max Dietrich <mail@mxd.codes>",
  "repository": "github:dietrichmax/docker-staticmaps",
  "scripts": {
    "format": "prettier --write .",
    "dev": "npm run build:client && nodemon --watch src --watch .env --ext ts,js -I --exec node --experimental-specifier-resolution=node --loader ts-node/esm ./src/server.ts",
    "test": "jest --coverage",
    "build:server": "webpack --config webpack.config.js",
    "build:client": "webpack --config webpack.client.config.js",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/server.cjs"
  },
  "type": "module",
  "main": "dist/server.cjs",
  "dependencies": {
    "@mapbox/polyline": "^1.2.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "node-cache": "^5.1.2",
    "pdfkit": "^0.19.1",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/mapbox__polyline": "^1.0.5",
    "@types/node": "^26.0.0",
    "@types/pdfkit": "^0.17.6",
    "css-loader": "^7.1.4",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "ol": "^10.9.0",
    "prettier": "^3.8.4",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "webpack": "^5.107.1",
    "webpack-cli": "^7.0.3",
    "webpack-node-externals": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
